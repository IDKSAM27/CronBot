# Core credentials
CLG_EMAIL=your_email@example.com
CLG_PASS=your_password_here
GEMINI_API_KEY=your_gemini_api_key_here

# Skills to always include in diary output
COMPULSORY_SKILLS=Git, Docker

# LLM field character limits
WORK_SUMMARY_MIN_CHARS=300
WORK_SUMMARY_MAX_CHARS=500

LEARNINGS_MIN_CHARS=250
LEARNINGS_MAX_CHARS=500

BLOCKERS_MIN_CHARS=100
BLOCKERS_MAX_CHARS=200

# Allowed small deviation from min/max before strict rejection.
# Example: with tolerance=40 and max=500, up to 540 is accepted.
FIELD_CHAR_TOLERANCE=40

# Gemini rate-limit retry behavior.
# max_retries=0 means unlimited retries (wait and continue).
LLM_RATE_LIMIT_RETRY_BASE_SECONDS=8
LLM_RATE_LIMIT_RETRY_MAX_WAIT_SECONDS=300
LLM_RATE_LIMIT_MAX_RETRIES=0
